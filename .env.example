# Neon Postgres: conexión principal. Obligatorio para que el panel admin use la base de datos.
# Obtén la URL desde el panel de Neon (Connection string). No subas este archivo con valores reales.
DATABASE_URL=

# Opcional: si usas migraciones o herramientas que requieran conexión sin pooler:
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=

# Vercel Blob: requerido para subir imágenes y documentos reales desde el panel admin.
# En producción, Vercel lo inyecta al conectar el proyecto con Blob.
# En local, usa `vercel env pull` o añade el token manualmente en `.env.local`.
BLOB_READ_WRITE_TOKEN=

# Resend: envío de correos a suscriptores cuando se publican noticias o eventos.
# Sin esta variable las suscripciones se guardan en Neon pero no se envían correos.
# Crea una cuenta en https://resend.com y verifica tu dominio.
RESEND_API_KEY=

# Opcional: remitente de los correos (ej. "REGULATEL <noticias@tudominio.org>").
# Por defecto se usa el dominio de prueba de Resend.
# NEWSLETTER_FROM_EMAIL=

# Opcional: URL base del sitio para enlaces en los correos (por defecto Vercel o regulatel.org).
# SITE_URL=
